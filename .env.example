# ===== Tapeline env template =====
# Copy to `.env` and fill in real values. NEVER commit .env.

# ---- App ----
APP_NAME=Tapeline
APP_ENV=development          # development | staging | production
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ---- Database ----
# Default: local SQLite (works in CI + first-run dev without external setup).
# For staging/prod override with a real Postgres URL:
#   DATABASE_URL=postgresql+psycopg://user:pass@HOST:5432/tapeline   (Supabase, Neon)
DATABASE_URL=sqlite+aiosqlite:///./tapeline_dev.sqlite

# ---- Market data (Massive — formerly Polygon.io, rebranded 2025-10-30) ----
# https://massive.com — Stocks Starter tier ($29/mo) has commercial redistribution rights.
# api.polygon.io still works during the grace period; api.massive.com is canonical.
MASSIVE_API_KEY=
# Optional sandbox / failover override (default https://api.massive.com)
# MASSIVE_BASE_URL=
# ---- Legacy Polygon keys (drop-in supported during grace period) ----
# Leave blank if you signed up post-rebrand.
POLYGON_API_KEY=

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ---- Billing (Stripe) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=alerts@tapeline.io

# ---- Telegram (optional, per-user) ----
# Premium tier only — user provides own chat_id; we store + push on alerts
TELEGRAM_BOT_TOKEN=

# ---- SMS (Twilio, optional) ----
# Premium tier only. Twilio costs ~$0.008 per SMS in US (more elsewhere).
# Without these set, SMS alerts log a skip and never send.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Web Push (VAPID) ----
# Generate keys with https://vapidkeys.com/ — paste both into VAPID_*_KEY.
# Also set NEXT_PUBLIC_VAPID_PUBLIC_KEY in frontend/.env.local to the same public key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:owner@tapeline.io

# ---- Finnhub (fundamentals + insider Form 4 + earnings/IPO calendars) ----
# Free tier (60 calls/min) covers Tapeline at https://finnhub.io/dashboard
# Without a key, sub_fundamentals stays random and calendars use mock data.
FINNHUB_API_KEY=

# ---- Bot protection (Cloudflare Turnstile, optional) ----
# Free at https://www.cloudflare.com/products/turnstile/
# When unset, Turnstile verification is a pass-through (dev mode).
# Honeypot + disposable-email blocking always active.
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ---- FRED (Federal Reserve Economic Data) ----
# Free at https://fred.stlouisfed.org/docs/api/api_key.html
# Provides live DXY, 10Y, VIX. Without a key, fetch_regime uses hardcoded values.
FRED_API_KEY=

# ---- Scoring worker ----
SCORE_REFRESH_SECONDS=60     # how often the worker re-scores the universe (per tick)
# Feature gating lives in backend/app/services/tier.py — no env flags needed.
