# ===== Tapeline env template =====
# Copy to `.env` and fill in real values. NEVER commit .env.

# ---- App ----
APP_NAME=Tapeline
APP_ENV=development          # development | staging | production
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ---- Database ----
# Supabase or Neon connection string
DATABASE_URL=postgresql://user:pass@host:5432/tapeline

# ---- Market data (Polygon.io) ----
# https://polygon.io — Starter tier ($29/mo) has commercial redistribution rights
POLYGON_API_KEY=
POLYGON_TIER=starter         # starter | developer | advanced
POLYGON_FEED=sip

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ---- Billing (Stripe) ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM=alerts@tapeline.io

# ---- Telegram (optional, per-user) ----
# Premium tier only — user provides own chat_id; we store + push on alerts
TELEGRAM_BOT_TOKEN=

# ---- Quiver QuantData (elite 13F holdings) ----
# Free tier available at https://api.quiverquant.com/
# Without a key, the smart-money sub-score falls back to mock data.
QUIVER_API_KEY=

# ---- Bot protection (Cloudflare Turnstile, optional) ----
# Free at https://www.cloudflare.com/products/turnstile/
# When unset, Turnstile verification is a pass-through (dev mode).
# Honeypot + disposable-email blocking always active.
CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# ---- Scoring worker ----
SCORE_REFRESH_SECONDS=60     # how often to rescore during market hours
SNAPSHOT_REFRESH_SECONDS=30  # how often to refresh live snapshot

# ---- Feature flags ----
FEATURE_CONGRESS_TAB=true
FEATURE_TELEGRAM_ALERTS=true
FEATURE_CSV_EXPORT=true
