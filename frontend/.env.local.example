NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare Turnstile (bot protection, optional)
# When set, the signup form renders the Turnstile widget and submits a token.
# When unset, the form works without it (honeypot still active).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ----------------------------------------------------------------------
# Founder disclosure — gates the Person/E-E-A-T schema across the site.
# ----------------------------------------------------------------------
# Trigger condition: n=100 scored + back-checked picks on /scorecard.
# Coordinate the flip with the launch of /blog/100-picks-in-public.
# See C:\Tapeline\seo-tools\disclosure\ for the full checklist before flipping.
#
# Activation requires: NEXT_PUBLIC_FOUNDER_DISCLOSED=true AND NAME is set
# AND at least one of LINKEDIN/X. Otherwise schema stays Organization-only.
NEXT_PUBLIC_FOUNDER_DISCLOSED=false
NEXT_PUBLIC_FOUNDER_NAME=
NEXT_PUBLIC_FOUNDER_LINKEDIN=
NEXT_PUBLIC_FOUNDER_X=
NEXT_PUBLIC_FOUNDER_GITHUB=https://github.com/cham-p24
NEXT_PUBLIC_FOUNDER_HEADSHOT_URL=
