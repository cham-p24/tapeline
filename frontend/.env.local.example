NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare Turnstile (bot protection, optional)
# When set, the signup form renders the Turnstile widget and submits a token.
# When unset, the form works without it (honeypot still active).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# PostHog product analytics (optional)
# Provides funnel + retention + event-level inspection on top of Vercel
# Analytics' page-level traffic counts. Free tier is 1M events/month.
#
# To enable:
#   1. Create a project at https://app.posthog.com
#   2. Settings → Project → API Keys → copy the Project API Key
#   3. Set NEXT_PUBLIC_POSTHOG_KEY here (and in Vercel env vars for prod)
#   4. Optional: set NEXT_PUBLIC_POSTHOG_HOST to https://eu.i.posthog.com
#      if you signed up on EU cloud (default is US cloud).
#
# When unset, the SDK is never loaded and no events are sent.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google tag — GA4 (analytics) + Google Ads (paid-search conversion tracking).
# Both share one gtag.js loader (app/layout.tsx).
#
# GA4: defaults to the prod property (G-YRK73W9NS9) in code, so prod tracks
# without env config. Override per-environment with NEXT_PUBLIC_GA4_ID, or set
# it to an empty string to disable.
NEXT_PUBLIC_GA4_ID=
#
# Google Ads conversion tracking — lets a paid search campaign know which clicks
# convert (Smart Bidding / ROAS depend on it). The AW-ID (AW-18169833652) and the
# sign_up + subscribe labels are HARDCODED DEFAULTS in code (app/layout.tsx +
# lib/gtag.ts) and live in prod, so signups AND paid subscriptions already count
# as conversions with NO env config. The vars below are optional per-environment
# OVERRIDES. To add a NEW conversion (e.g. start_trial):
#   1. Google Ads -> Goals -> Conversions -> + New conversion action -> Website.
#      Create one. Google gives a tag id like AW-1234567890 and a conversion
#      label like AbC-D_efGhIjK.
#   2. Set the matching label below to the conversion-label string only (do NOT
#      include the "AW-.../" prefix — lib/gtag.ts joins them). The matching
#      trackEvent (sign_up / start_trial / subscribe) then fires the Ads
#      conversion alongside the GA4 event.
# sign_up + subscribe forward by default (hardcoded). start_trial stays no-op by
# design — it fires at the same instant as sign_up, so a separate Ads conversion
# would double-count. GA4 is unaffected either way.
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_TRIAL_LABEL=
NEXT_PUBLIC_GOOGLE_ADS_SUBSCRIBE_LABEL=

# ----------------------------------------------------------------------
# Founder disclosure — gates the Person/E-E-A-T schema across the site.
# ----------------------------------------------------------------------
# Trigger condition: n=100 scored + back-checked picks on /scorecard.
# Coordinate the flip with the launch of /blog/100-picks-in-public.
# See C:\Tapeline\seo-tools\disclosure\ for the full checklist before flipping.
#
# Activation requires: NEXT_PUBLIC_FOUNDER_DISCLOSED=true AND NAME is set
# AND at least one of LINKEDIN/X. Otherwise schema stays Organization-only.
NEXT_PUBLIC_FOUNDER_DISCLOSED=false
NEXT_PUBLIC_FOUNDER_NAME=
NEXT_PUBLIC_FOUNDER_LINKEDIN=
NEXT_PUBLIC_FOUNDER_X=
NEXT_PUBLIC_FOUNDER_GITHUB=https://github.com/cham-p24
NEXT_PUBLIC_FOUNDER_HEADSHOT_URL=
